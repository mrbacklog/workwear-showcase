# Showcase Environment Variables
#
# Copy this file to .env.local:
#   cp .env.local.example .env.local

# --- Offline Development ---
# No environment variables needed for offline development.
# Just run: npm run dev:offline

# --- Live Sync (fetch data from backend API) ---
# Required for: npm run sync / npm run sync:force
BACKEND_URL=https://api.databiz.app
AGENT_SECRET=<your-agent-secret>

# --- Runtime API (change requests from showcase to PIM) ---
NEXT_PUBLIC_API_URL=https://api.databiz.app
