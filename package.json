{
  "name": "workwear-showcase",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8500",
    "dev:offline": "tsx scripts/load-fixtures.ts && next dev -p 8500",
    "build": "next build",
    "start": "next start -p 8500",
    "sync": "tsx scripts/sync-products.ts",
    "sync:force": "tsx scripts/sync-products.ts --force",
    "sync:build": "tsx scripts/sync-products.ts --build",
    "sync:dry-run": "tsx scripts/sync-products.ts --dry-run",
    "sync:deploy": "tsx scripts/sync-products.ts --build --deploy",
    "fixtures:load": "tsx scripts/load-fixtures.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.2",
    "minisearch": "^7.1.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sharp": "^0.31.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.13",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
